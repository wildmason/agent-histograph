{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentlogCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "schema_version",
    "summary",
    "touched_paths",
    "verification",
    "decisions",
    "risks",
    "asks",
    "next_action",
    "health_draft"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "checkpoint"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "0.1"
      ]
    },
    "summary": {
      "type": "string"
    },
    "touched_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "choice",
          "rationale",
          "alternatives",
          "reversibility",
          "confidence",
          "class",
          "materiality",
          "human_involved"
        ],
        "properties": {
          "topic": {
            "type": "string"
          },
          "choice": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reversibility": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "class": {
            "type": "string",
            "enum": [
              "billing",
              "license",
              "auth",
              "migration",
              "public_api",
              "dependency",
              "data_loss",
              "local",
              "none"
            ]
          },
          "materiality": {
            "type": "string",
            "enum": [
              "ask_now",
              "record",
              "suppress"
            ]
          },
          "human_involved": {
            "type": "boolean"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "summary",
          "severity"
        ],
        "properties": {
          "summary": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "asks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "blocking"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "next_action": {
      "type": "string"
    },
    "health_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic",
        "decision",
        "reason",
        "human_involved"
      ],
      "properties": {
        "topic": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "human_involved": {
          "type": "boolean"
        }
      }
    }
  }
}

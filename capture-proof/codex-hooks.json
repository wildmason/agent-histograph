{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_session_start.py",
            "commandWindows": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_posttooluse.py",
            "commandWindows": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_posttooluse.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_stop_capture.py",
            "commandWindows": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_stop_capture.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_precompact_marker.py",
            "commandWindows": "python C:/Users/Matt/Documents/development/agent-histograph/capture-proof/codex_precompact_marker.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
